# ============================================================
# EXEMPLE DE FICHIER D'ENVIRONNEMENT
# Copiez ce fichier, renommez-le en ".env" et remplissez vos clés
# ============================================================

# 1. SUPABASE KEYS (Requis pour l'application Frontend)
# Allez dans Supabase Dashboard -> Project Settings -> API
# Copiez "Project URL"
VITE_SUPABASE_URL=https://votrenomdeprojet.supabase.co

# Copiez la clé "anon" (Project API keys) -> NE METTEZ PAS LA CLÉ "service_role"
VITE_SUPABASE_KEY=

# ============================================================
# 2. BACKEND API (Optionnel)
# (L'API Python locale n'est plus utilisée comme méthode principale.
# Elle servira de solution de secours si Supabase Storage échoue).
VITE_API_URL=

# ============================================================
# 3. CLOUDFLARE EDGE FUNCTIONS (Backend - Notifications & Invites)
# Ces clés DOIVENT être ajoutées dans les paramètres Cloudflare
# (Ne pas utiliser le préfixe VITE_ car elles ne doivent pas être publiques)
#
# Supabase URL et clé service_role pour les fonctions serverless
SUPABASE_URL=https://votrenomdeprojet.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Clé API Resend pour l'envoi d'emails
RESEND_API_KEY=

# (Optionnel) Secret de vérification du webhook Resend
# Trouvable dans: Resend Dashboard -> Settings -> Webhooks -> Signing Secret
# Si défini, le webhook vérifiera la signature de chaque requête entrante
RESEND_WEBHOOK_SECRET=
